{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://YOUR-BACKEND-ON-RENDER.onrender.com/api/$1",
      "headers": { "Access-Control-Allow-Origin": "*" }
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/((?!api).*)",
      "dest": "/public/index.html"
    }
  ]
}
